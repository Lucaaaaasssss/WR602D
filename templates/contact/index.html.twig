{% extends 'base.html.twig' %}

{% block title %}Contacts - PDFGen{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-2 fade-in">
    <h1 class="page-title mb-0">Contacts</h1>
    <a href="{{ path('app_contact_new') }}" class="btn-lime">
        <i class="bi bi-person-plus-fill"></i> Nouveau Contact
    </a>
</div>
<p class="page-sub fade-in fade-in-1">Gerez vos contacts pour les generations PDF</p>

<div class="card-dark fade-in fade-in-2">
    <div class="card-pad">
        {% if contacts|length > 0 %}
        <table class="tbl">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nom</th>
                    <th>Prenom</th>
                    <th>Email</th>
                    <th>Generations</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for contact in contacts %}
                <tr>
                    <td><span class="tag">#{{ contact.id }}</span></td>
                    <td>{{ contact.lastname }}</td>
                    <td>{{ contact.firstname }}</td>
                    <td>{{ contact.email }}</td>
                    <td><span class="tag">{{ contact.generations|length }}</span></td>
                    <td>
                        <div class="d-flex gap-2">
                            <a href="{{ path('app_contact_show', {id: contact.id}) }}" class="btn-icon" title="Voir">
                                <i class="bi bi-eye-fill"></i>
                            </a>
                            <a href="{{ path('app_contact_edit', {id: contact.id}) }}" class="btn-icon" title="Modifier">
                                <i class="bi bi-pencil-fill"></i>
                            </a>
                            <form action="{{ path('app_contact_delete', {id: contact.id}) }}" method="POST" class="d-inline"
                                  onsubmit="return confirm('Supprimer ce contact ?')">
                                <button type="submit" class="btn-icon danger" title="Supprimer">
                                    <i class="bi bi-trash-fill"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
        <div class="empty-state">
            <i class="bi bi-people"></i>
            <h4>Aucun contact</h4>
            <p>Commencez par ajouter votre premier contact</p>
            <a href="{{ path('app_contact_new') }}" class="btn-lime">
                <i class="bi bi-person-plus-fill"></i> Ajouter un contact
            </a>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
