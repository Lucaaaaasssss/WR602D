{% extends 'base.html.twig' %}

{% block title %}{{ contact.firstname }} {{ contact.lastname }} - PDFGen{% endblock %}

{% block body %}
<h1 class="page-title fade-in">{{ contact.firstname }} {{ contact.lastname }}</h1>
<p class="page-sub fade-in fade-in-1">Details du contact</p>

<div class="row g-4">
    <div class="col-lg-6 fade-in fade-in-2">
        <div class="card-dark">
            <div class="card-head">
                <i class="bi bi-info-circle-fill"></i> Informations
            </div>
            <div class="card-pad">
                <div class="info-row">
                    <i class="bi bi-hash"></i>
                    <div>
                        <div class="label">ID</div>
                        <div class="value">#{{ contact.id }}</div>
                    </div>
                </div>
                <div class="info-row">
                    <i class="bi bi-person-fill"></i>
                    <div>
                        <div class="label">Prenom</div>
                        <div class="value">{{ contact.firstname }}</div>
                    </div>
                </div>
                <div class="info-row">
                    <i class="bi bi-person-badge-fill"></i>
                    <div>
                        <div class="label">Nom</div>
                        <div class="value">{{ contact.lastname }}</div>
                    </div>
                </div>
                <div class="info-row">
                    <i class="bi bi-envelope-fill"></i>
                    <div>
                        <div class="label">Email</div>
                        <div class="value">{{ contact.email }}</div>
                    </div>
                </div>
                <div class="info-row">
                    <i class="bi bi-file-earmark-pdf-fill"></i>
                    <div>
                        <div class="label">Generations</div>
                        <div class="value"><span class="tag">{{ contact.generations|length }}</span></div>
                    </div>
                </div>

                <div class="d-flex gap-3 mt-4">
                    <a href="{{ path('app_contact_edit', {id: contact.id}) }}" class="btn-lime">
                        <i class="bi bi-pencil-fill"></i> Modifier
                    </a>
                    <a href="{{ path('app_contact_index') }}" class="btn-outline">
                        <i class="bi bi-arrow-left"></i> Retour
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
