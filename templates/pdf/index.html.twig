{% extends 'base.html.twig' %}

{% block title %}Generer PDF - PDFGen{% endblock %}

{% block body %}
<h1 class="page-title fade-in">Generer un PDF</h1>
<p class="page-sub fade-in fade-in-1">Convertissez du HTML ou une page web en PDF</p>

<div class="row g-4">
    <div class="col-lg-7 fade-in fade-in-1">
        <div class="card-dark">
            <div class="card-head-lime">
                <i class="bi bi-code-slash"></i> Depuis du HTML
            </div>
            <div class="card-pad">
                <form action="{{ path('app_pdf_generate') }}" method="POST" target="_blank">
                    <div class="mb-4">
                        <label for="html" class="form-label">Code HTML</label>
                        <textarea class="form-control" id="html" name="html" rows="14"><!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Mon Document</title>
    <style>
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            margin: 50px;
            color: #1e293b;
            line-height: 1.6;
        }
        h1 {
            color: #1F3A31;
            border-bottom: 3px solid #DEFCA6;
            padding-bottom: 15px;
            margin-bottom: 30px;
        }
        .content {
            background: #F7FFE8;
            padding: 25px;
            border-radius: 12px;
            border-left: 4px solid #1F3A31;
        }
        .footer {
            margin-top: 50px;
            text-align: center;
            color: #94a3b8;
            font-size: 12px;
        }
    </style>
</head>
<body>
    <h1>Mon Document PDF</h1>
    <div class="content">
        <p>Ceci est un exemple de document PDF genere avec <strong>Gotenberg</strong>.</p>
        <p>Personnalisez ce contenu HTML selon vos besoins !</p>
    </div>
    <div class="footer">
        <p>Genere avec PDFGen - {{ "now"|date("d/m/Y H:i") }}</p>
    </div>
</body>
</html></textarea>
                    </div>
                    <button type="submit" class="btn-lime" style="width:100%;justify-content:center;">
                        <i class="bi bi-file-earmark-pdf"></i> Generer le PDF
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card-dark mb-4 fade-in fade-in-2">
            <div class="card-head">
                <i class="bi bi-link-45deg"></i> Depuis une URL
            </div>
            <div class="card-pad">
                <form action="{{ path('app_pdf_from_url') }}" method="POST" target="_blank">
                    <div class="mb-4">
                        <label for="url" class="form-label">URL de la page web</label>
                        <input type="url" class="form-control" id="url" name="url"
                               placeholder="https://example.com" required>
                    </div>
                    <div class="alert-bar mb-4">
                        <i class="bi bi-info-circle-fill"></i>
                        La page sera capturee telle qu'elle apparait dans un navigateur Chrome.
                    </div>
                    <button type="submit" class="btn-lime" style="width:100%;justify-content:center;">
                        <i class="bi bi-globe"></i> Convertir en PDF
                    </button>
                </form>
            </div>
        </div>

        <div class="card-dark fade-in fade-in-3">
            <div class="card-head">
                <i class="bi bi-lightbulb-fill"></i> Conseils
            </div>
            <div class="card-pad">
                <div class="qlink">
                    <i class="bi bi-palette-fill"></i>
                    <span>Utilisez des styles CSS inline</span>
                </div>
                <div class="qlink">
                    <i class="bi bi-image-fill"></i>
                    <span>Images en URL absolue</span>
                </div>
                <div class="qlink">
                    <i class="bi bi-file-earmark-ruled"></i>
                    <span>Format de sortie : A4</span>
                </div>
                <div class="qlink">
                    <i class="bi bi-fonts"></i>
                    <span>Polices web supportees</span>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
