<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}PDFGen{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <style>
        :root {
            --lime: #DEFCA6;
            --forest: #102B22;
            --bg: #1F3A31;
            --cream: #F7FFE8;
            --bg-card: rgba(16, 43, 34, 0.6);
            --border: rgba(222, 252, 166, 0.12);
            --border-hover: rgba(222, 252, 166, 0.25);
            --text: #F7FFE8;
            --text-dim: rgba(247, 255, 232, 0.5);
            --text-mid: rgba(247, 255, 232, 0.7);
            --radius: 16px;
            --radius-sm: 10px;
            --sidebar-w: 260px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        /* ── Noise texture overlay ── */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            z-index: 0;
            pointer-events: none;
            opacity: 0.03;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
            background-repeat: repeat;
            background-size: 200px;
        }

        /* ── Sidebar ── */
        .sidebar {
            position: fixed;
            left: 0; top: 0;
            width: var(--sidebar-w);
            height: 100vh;
            background: var(--forest);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            z-index: 100;
        }

        .sidebar-brand {
            padding: 32px 28px;
            border-bottom: 1px solid var(--border);
        }

        .sidebar-brand a {
            display: flex;
            align-items: center;
            gap: 14px;
            text-decoration: none;
        }

        .brand-mark {
            width: 40px; height: 40px;
            background: var(--lime);
            border-radius: 12px;
            display: grid;
            place-items: center;
            color: var(--forest);
            font-size: 1.1rem;
        }

        .brand-name {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--text);
            letter-spacing: -0.5px;
        }

        .brand-name span { color: var(--lime); }

        .sidebar-nav {
            padding: 24px 16px;
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .sidebar-nav a {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 12px 16px;
            border-radius: var(--radius-sm);
            color: var(--text-dim);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            transition: all 0.2s ease;
        }

        .sidebar-nav a i { font-size: 1.15rem; width: 20px; text-align: center; }

        .sidebar-nav a:hover {
            color: var(--text);
            background: rgba(222, 252, 166, 0.06);
        }

        .sidebar-nav a.active {
            color: var(--forest);
            background: var(--lime);
            font-weight: 600;
        }

        /* ── Main ── */
        .main { margin-left: var(--sidebar-w); padding: 48px 48px 80px; position: relative; z-index: 1; }

        /* ── Typography ── */
        .page-title {
            font-size: 2rem;
            font-weight: 700;
            color: var(--lime);
            letter-spacing: -0.8px;
            margin-bottom: 6px;
        }

        .page-sub {
            color: var(--text-dim);
            font-size: 0.95rem;
            margin-bottom: 40px;
        }

        /* ── Cards ── */
        .card-dark {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden;
            transition: border-color 0.3s ease, box-shadow 0.3s ease;
        }

        .card-dark:hover {
            border-color: var(--border-hover);
            box-shadow: 0 8px 40px rgba(0,0,0,0.2);
        }

        .card-light {
            background: var(--cream);
            border-radius: var(--radius);
            color: var(--forest);
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .card-light:hover {
            transform: translateY(-4px);
            box-shadow: 0 16px 48px rgba(0,0,0,0.2);
        }

        .card-pad { padding: 28px; }

        .card-head {
            padding: 20px 28px;
            border-bottom: 1px solid var(--border);
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: var(--text-mid);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .card-head-lime {
            padding: 20px 28px;
            background: var(--lime);
            color: var(--forest);
            font-weight: 600;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        /* ── Stat blocks ── */
        .stat-block {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 28px;
            transition: border-color 0.3s ease;
        }

        .stat-block:hover { border-color: var(--border-hover); }

        .stat-label {
            font-size: 0.78rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-dim);
            margin-bottom: 12px;
            font-weight: 500;
        }

        .stat-value {
            font-size: 2.4rem;
            font-weight: 700;
            color: var(--lime);
            letter-spacing: -1px;
            line-height: 1;
        }

        /* ── Buttons ── */
        .btn-lime {
            background: var(--lime);
            color: var(--forest);
            border: none;
            padding: 12px 28px;
            border-radius: var(--radius-sm);
            font-weight: 600;
            font-size: 0.9rem;
            font-family: inherit;
            cursor: pointer;
            transition: all 0.2s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-lime i { color: var(--forest); }

        .btn-lime:hover {
            background: #edffc0;
            color: var(--forest);
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(222, 252, 166, 0.2);
        }

        .btn-outline {
            background: transparent;
            color: var(--text-mid);
            border: 1px solid var(--border);
            padding: 10px 22px;
            border-radius: var(--radius-sm);
            font-weight: 500;
            font-size: 0.875rem;
            font-family: inherit;
            cursor: pointer;
            transition: all 0.2s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .btn-outline:hover {
            border-color: var(--lime);
            color: var(--lime);
            background: rgba(222, 252, 166, 0.05);
        }

        .btn-sm { padding: 8px 14px; font-size: 0.8rem; }

        .btn-icon {
            width: 36px; height: 36px;
            padding: 0;
            display: grid;
            place-items: center;
            border-radius: var(--radius-sm);
            background: transparent;
            border: 1px solid var(--border);
            color: var(--text-dim);
            cursor: pointer;
            transition: all 0.2s ease;
            text-decoration: none;
        }

        .btn-icon:hover { border-color: var(--lime); color: var(--lime); }
        .btn-icon.danger:hover { border-color: #f87171; color: #f87171; }

        /* ── Tables ── */
        .tbl { width: 100%; border-collapse: collapse; }
        .tbl th {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-dim);
            font-weight: 500;
            padding: 14px 16px;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }
        .tbl td {
            padding: 16px;
            border-bottom: 1px solid var(--border);
            font-size: 0.9rem;
            color: var(--text-mid);
            vertical-align: middle;
        }
        .tbl tbody tr { transition: background 0.15s ease; }
        .tbl tbody tr:hover { background: rgba(222, 252, 166, 0.03); }
        .tbl tbody tr:last-child td { border-bottom: none; }

        /* ── Tag / Badge ── */
        .tag {
            display: inline-block;
            background: rgba(222, 252, 166, 0.1);
            color: var(--lime);
            padding: 4px 12px;
            border-radius: 6px;
            font-size: 0.8rem;
            font-weight: 600;
        }

        /* ── Forms ── */
        .form-control, .form-select {
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 14px 18px;
            color: var(--text);
            font-family: inherit;
            font-size: 0.925rem;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        .form-control:focus, .form-select:focus {
            background: rgba(255,255,255,0.06);
            border-color: var(--lime);
            box-shadow: 0 0 0 3px rgba(222, 252, 166, 0.1);
            color: var(--text);
        }

        .form-control::placeholder { color: var(--text-dim); }

        .form-label {
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: var(--text-mid);
            margin-bottom: 8px;
        }

        textarea.form-control {
            font-family: 'DM Mono', monospace;
            font-size: 0.85rem;
            line-height: 1.7;
            min-height: 280px;
        }

        /* ── Alerts ── */
        .alert-bar {
            background: rgba(222, 252, 166, 0.08);
            border: 1px solid rgba(222, 252, 166, 0.15);
            border-radius: var(--radius-sm);
            padding: 16px 20px;
            color: var(--text-mid);
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .alert-bar i { color: var(--lime); }

        /* ── Flashes ── */
        .flash-msg {
            background: rgba(222, 252, 166, 0.1);
            border-left: 3px solid var(--lime);
            border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
            padding: 16px 24px;
            color: var(--text);
            margin-bottom: 24px;
            font-size: 0.9rem;
        }

        .flash-msg.flash-error {
            background: rgba(248, 113, 113, 0.1);
            border-left-color: #f87171;
            color: #fca5a5;
        }

        .flash-msg.flash-error a {
            color: var(--lime);
            font-weight: 600;
            text-decoration: none;
        }

        .flash-msg.flash-error a:hover { text-decoration: underline; }

        /* ── Empty State ── */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
        }

        .empty-state > i {
            font-size: 3rem;
            color: var(--text-dim);
            margin-bottom: 16px;
            opacity: 0.4;
        }

        .empty-state h4 {
            color: var(--text-mid);
            font-weight: 600;
            font-size: 1.1rem;
            margin-bottom: 8px;
        }

        .empty-state p {
            color: var(--text-dim);
            font-size: 0.9rem;
            margin-bottom: 24px;
        }

        /* ── Info row ── */
        .info-row {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 16px 0;
            border-bottom: 1px solid var(--border);
        }

        .info-row:last-child { border-bottom: none; }

        .info-row i { color: var(--lime); font-size: 1.1rem; width: 20px; text-align: center; }

        .info-row .label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: var(--text-dim);
        }

        .info-row .value { color: var(--text); font-weight: 500; font-size: 0.95rem; }

        /* ── Quick links ── */
        .qlink {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 16px;
            border-radius: var(--radius-sm);
            color: var(--text-mid);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            transition: all 0.2s ease;
            border: 1px solid transparent;
        }

        .qlink i { color: var(--lime); font-size: 1rem; }

        .qlink:hover {
            background: rgba(222, 252, 166, 0.05);
            border-color: var(--border);
            color: var(--text);
        }

        /* ── Sidebar user ── */
        .sidebar-user {
            padding: 20px 16px;
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
        }

        .sidebar-user-info {
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 0;
        }

        .sidebar-user-avatar {
            width: 36px; height: 36px;
            border-radius: 10px;
            background: var(--lime);
            color: var(--forest);
            font-size: 0.75rem;
            font-weight: 700;
            display: grid;
            place-items: center;
            flex-shrink: 0;
        }

        .sidebar-user-name {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--text);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .sidebar-user-role {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-dim);
        }

        .sidebar-logout {
            width: 32px; height: 32px;
            display: grid;
            place-items: center;
            border-radius: 8px;
            color: var(--text-dim);
            text-decoration: none;
            transition: all 0.2s ease;
            flex-shrink: 0;
        }

        .sidebar-logout:hover {
            background: rgba(248, 113, 113, 0.1);
            color: #f87171;
        }

        .sidebar-auth {
            padding: 20px 16px;
            border-top: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        /* ── Scrollbar ── */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--text-dim); }

        /* ── Responsive ── */
        @media (max-width: 992px) {
            .sidebar { width: 100%; height: auto; position: relative; }
            .sidebar-nav { flex-direction: row; overflow-x: auto; gap: 0; }
            .sidebar-nav a { white-space: nowrap; }
            .main { margin-left: 0; padding: 24px; }
        }

        /* ── Fade-in animation ── */
        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .fade-in { animation: fadeUp 0.4s ease both; }
        .fade-in-1 { animation-delay: 0.05s; }
        .fade-in-2 { animation-delay: 0.1s; }
        .fade-in-3 { animation-delay: 0.15s; }
        .fade-in-4 { animation-delay: 0.2s; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <nav class="sidebar">
        <div class="sidebar-brand">
            <a href="{{ path('app_dashboard') }}">
                <div class="brand-mark"><i class="bi bi-file-earmark-pdf-fill"></i></div>
                <div class="brand-name">PDF<span>Gen</span></div>
            </a>
        </div>
        <div class="sidebar-nav">
            <a href="{{ path('app_dashboard') }}" class="{% if app.request.attributes.get('_route') == 'app_dashboard' %}active{% endif %}">
                <i class="bi bi-grid-1x2"></i> Dashboard
            </a>
            <a href="{{ path('app_pdf_page') }}" class="{% if 'pdf' in app.request.attributes.get('_route') %}active{% endif %}">
                <i class="bi bi-file-earmark-pdf"></i> Generer PDF
            </a>
            <a href="{{ path('app_contact_index') }}" class="{% if 'contact' in app.request.attributes.get('_route') %}active{% endif %}">
                <i class="bi bi-people"></i> Contacts
            </a>
            <a href="{{ path('app_generation_index') }}" class="{% if 'generation' in app.request.attributes.get('_route') %}active{% endif %}">
                <i class="bi bi-clock-history"></i> Historique
            </a>
            <a href="{{ path('app_plan_index') }}" class="{% if 'plan' in app.request.attributes.get('_route') %}active{% endif %}">
                <i class="bi bi-gem"></i> Plans
            </a>
        </div>
        {% if app.user %}
        <div class="sidebar-user">
            <div class="sidebar-user-info">
                <div class="sidebar-user-avatar">{{ app.user.firstname|first }}{{ app.user.lastname|first }}</div>
                <div>
                    <div class="sidebar-user-name">{{ app.user.firstname }} {{ app.user.lastname }}</div>
                    <div class="sidebar-user-role">
                        {% if 'ROLE_ADMIN' in app.user.roles %}Admin{% else %}Utilisateur{% endif %}
                    </div>
                </div>
            </div>
            <a href="{{ path('app_logout') }}" class="sidebar-logout" title="Deconnexion">
                <i class="bi bi-box-arrow-right"></i>
            </a>
        </div>
        {% else %}
        <div class="sidebar-auth">
            <a href="{{ path('app_login') }}" class="btn-outline" style="width:100%;justify-content:center;">
                <i class="bi bi-box-arrow-in-right"></i> Connexion
            </a>
            <a href="{{ path('app_register') }}" class="btn-lime" style="width:100%;justify-content:center;">
                <i class="bi bi-person-plus-fill"></i> Inscription
            </a>
        </div>
        {% endif %}
    </nav>

    <main class="main">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="flash-msg {% if label == 'error' %}flash-error{% endif %}">
                    {% if label == 'error' %}<i class="bi bi-exclamation-circle-fill me-2"></i>{% endif %}
                    {{ message|raw }}
                    {% if label == 'error' and not app.user %}
                        — <a href="{{ path('app_login') }}">Se connecter</a> ou <a href="{{ path('app_register') }}">Creer un compte</a>
                    {% endif %}
                </div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>
