{% extends 'base.html.twig' %}

{% block title %}Historique - PDFGen{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-2 fade-in">
    <h1 class="page-title mb-0">Historique</h1>
    <a href="{{ path('app_pdf_page') }}" class="btn-lime">
        <i class="bi bi-plus-lg"></i> Nouvelle Generation
    </a>
</div>
<p class="page-sub fade-in fade-in-1">Toutes vos generations de PDF</p>

<div class="card-dark fade-in fade-in-2">
    <div class="card-pad">
        {% if generations|length > 0 %}
        <table class="tbl">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Fichier</th>
                    <th>Date</th>
                    <th>Contacts</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for generation in generations %}
                <tr>
                    <td><span class="tag">#{{ generation.id }}</span></td>
                    <td>{{ generation.file }}</td>
                    <td>{{ generation.createdAt|date('d/m/Y H:i') }}</td>
                    <td>
                        {% for contact in generation.userContacts|slice(0, 3) %}
                        <span class="tag me-1">{{ contact.firstname }}</span>
                        {% else %}
                        <span style="color: var(--text-dim);">-</span>
                        {% endfor %}
                        {% if generation.userContacts|length > 3 %}
                        <span class="tag">+{{ generation.userContacts|length - 3 }}</span>
                        {% endif %}
                    </td>
                    <td>
                        <a href="{{ path('app_generation_show', {id: generation.id}) }}" class="btn-outline btn-sm">
                            <i class="bi bi-eye-fill"></i> Details
                        </a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% else %}
        <div class="empty-state">
            <i class="bi bi-clock-history"></i>
            <h4>Aucune generation</h4>
            <p>Commencez par generer votre premier PDF</p>
            <a href="{{ path('app_pdf_page') }}" class="btn-lime">
                <i class="bi bi-file-earmark-pdf"></i> Generer un PDF
            </a>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
