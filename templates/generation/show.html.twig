{% extends 'base.html.twig' %}

{% block title %}Generation #{{ generation.id }} - PDFGen{% endblock %}

{% block body %}
<h1 class="page-title fade-in">Generation #{{ generation.id }}</h1>
<p class="page-sub fade-in fade-in-1">Details de la generation</p>

<div class="row g-4">
    <div class="col-lg-6 fade-in fade-in-2">
        <div class="card-dark">
            <div class="card-head">
                <i class="bi bi-info-circle-fill"></i> Informations
            </div>
            <div class="card-pad">
                <div class="info-row">
                    <i class="bi bi-hash"></i>
                    <div>
                        <div class="label">ID</div>
                        <div class="value">#{{ generation.id }}</div>
                    </div>
                </div>
                <div class="info-row">
                    <i class="bi bi-file-earmark-pdf-fill"></i>
                    <div>
                        <div class="label">Fichier</div>
                        <div class="value">{{ generation.file }}</div>
                    </div>
                </div>
                <div class="info-row">
                    <i class="bi bi-calendar3"></i>
                    <div>
                        <div class="label">Date de creation</div>
                        <div class="value">{{ generation.createdAt|date('d/m/Y H:i:s') }}</div>
                    </div>
                </div>
                <div class="info-row">
                    <i class="bi bi-person-fill"></i>
                    <div>
                        <div class="label">Utilisateur</div>
                        <div class="value">
                            {% if generation.user %}
                            {{ generation.user.firstname }} {{ generation.user.lastname }}
                            {% else %}
                            <span style="color: var(--text-dim);">-</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6 fade-in fade-in-3">
        <div class="card-dark">
            <div class="card-head">
                <i class="bi bi-people-fill"></i> Contacts associes ({{ generation.userContacts|length }})
            </div>
            <div class="card-pad">
                {% if generation.userContacts|length > 0 %}
                {% for contact in generation.userContacts %}
                <div class="info-row">
                    <i class="bi bi-person-circle"></i>
                    <div class="flex-grow-1">
                        <div class="value">{{ contact.firstname }} {{ contact.lastname }}</div>
                        <div class="label">{{ contact.email }}</div>
                    </div>
                    <a href="{{ path('app_contact_show', {id: contact.id}) }}" class="btn-icon">
                        <i class="bi bi-eye-fill"></i>
                    </a>
                </div>
                {% endfor %}
                {% else %}
                <div class="empty-state">
                    <i class="bi bi-people"></i>
                    <h4>Aucun contact associe</h4>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<div class="mt-4 fade-in fade-in-4">
    <a href="{{ path('app_generation_index') }}" class="btn-outline">
        <i class="bi bi-arrow-left"></i> Retour a l'historique
    </a>
</div>
{% endblock %}
