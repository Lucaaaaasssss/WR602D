{% extends 'base.html.twig' %}

{% block title %}Dashboard - PDFGen{% endblock %}

{% block body %}
<h1 class="page-title fade-in">Dashboard</h1>
<p class="page-sub fade-in fade-in-1">Bienvenue sur votre espace de generation PDF</p>

<div class="row g-4 mb-5">
    <div class="col-lg-3 col-md-6 fade-in fade-in-1">
        <div class="stat-block">
            <div class="stat-label">PDF Generes</div>
            <div class="stat-value">{{ totalGenerations }}</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 fade-in fade-in-2">
        <div class="stat-block">
            <div class="stat-label">Contacts</div>
            <div class="stat-value">{{ totalContacts }}</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 fade-in fade-in-3">
        <div class="stat-block">
            <div class="stat-label">Plans Actifs</div>
            <div class="stat-value">{{ totalPlans }}</div>
        </div>
    </div>
    <div class="col-lg-3 col-md-6 fade-in fade-in-4">
        <div class="stat-block" style="display:flex;flex-direction:column;justify-content:center;align-items:center;">
            <a href="{{ path('app_pdf_page') }}" class="btn-lime">
                <i class="bi bi-plus-lg"></i> Nouveau PDF
            </a>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8 fade-in fade-in-2">
        <div class="card-dark">
            <div class="card-head">
                <i class="bi bi-clock-history"></i> Dernieres Generations
            </div>
            <div class="card-pad">
                {% if generations|length > 0 %}
                <table class="tbl">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Fichier</th>
                            <th>Date</th>
                            <th>Contacts</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for generation in generations %}
                        <tr>
                            <td><span class="tag">#{{ generation.id }}</span></td>
                            <td>{{ generation.file }}</td>
                            <td>{{ generation.createdAt|date('d/m/Y H:i') }}</td>
                            <td><span class="tag">{{ generation.userContacts|length }}</span></td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
                {% else %}
                <div class="empty-state">
                    <i class="bi bi-inbox"></i>
                    <h4>Aucune generation</h4>
                    <p>Commencez par generer votre premier PDF</p>
                    <a href="{{ path('app_pdf_page') }}" class="btn-lime">
                        <i class="bi bi-file-earmark-pdf"></i> Creer mon premier PDF
                    </a>
                </div>
                {% endif %}
            </div>
        </div>
    </div>

    <div class="col-lg-4 fade-in fade-in-3">
        <div class="card-dark">
            <div class="card-head">
                <i class="bi bi-lightning-fill"></i> Actions Rapides
            </div>
            <div class="card-pad">
                <a href="{{ path('app_pdf_page') }}" class="qlink">
                    <i class="bi bi-file-earmark-pdf-fill"></i>
                    <span>Generer un PDF</span>
                </a>
                <a href="{{ path('app_contact_new') }}" class="qlink">
                    <i class="bi bi-person-plus-fill"></i>
                    <span>Ajouter un contact</span>
                </a>
                <a href="{{ path('app_generation_index') }}" class="qlink">
                    <i class="bi bi-clock-history"></i>
                    <span>Voir l'historique</span>
                </a>
                <a href="{{ path('app_plan_index') }}" class="qlink">
                    <i class="bi bi-gem"></i>
                    <span>Voir les plans</span>
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
